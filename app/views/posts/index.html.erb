<h1>Feed</h1>
<ul>
  <% @posts.each do |post| %>
    <li>
      
      <h3><%= link_to post.title, post_path(post) %></h3>
      <% if user_signed_in? %>
        <span><%= post.user.username %></span>
      <% end %>
      <p><%= post.content %></p>
    </li>
  <% end %>
</ul>
<%= link_to 'Create New Post', new_post_path %>
