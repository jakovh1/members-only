<h1>Sign Up Form</h1>
<%= form_with model: @user do |form| %>
  <% @user.errors.full_messages_for(:email).each do |message| %>
    <div><%= message %></div>
  <% end %>
  <div>
    <%= form.label :email %>
    <%= form.email_field :email, value: @user[:email], placeholder: "Enter email here" %>
  </div>

  <% @user.errors.full_messages_for(:username).each do |message| %>
      <div><%= message %></div>
  <% end %>
  <div>
    <%= form.label :username %>
    <%= form.text_field :username, value: @user[:username], placeholder: "Enter username here" %>
  </div>

  <% @user.errors.full_messages_for(:password).each do |message| %>
      <div><%= message %></div>
  <% end %>
  <div>
    <%= form.label :password %>
    <%= form.password_field :password, value: @user[:password], placeholder: "Enter password here" %>
  </div>
  <%= form.submit %>
<% end %>